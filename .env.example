# Example environment overrides for GTEx-Link.
# Copy to .env and adjust as needed.

# uv performance optimization for WSL2/NTFS
# UV_LINK_MODE=copy
# UV_CACHE_DIR=/tmp/uv-cache

# Server
# GTEX_LINK_HOST=127.0.0.1
# GTEX_LINK_PORT=8000
# GTEX_LINK_LOG_LEVEL=INFO
# GTEX_LINK_LOG_FORMAT=console
# Exact request-boundary allowlists. Hosts do not include schemes or ports;
# write IPv6 loopback as ::1 (not [::1]). Wildcards are rejected in both lists.
# GTEX_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
# GTEX_LINK_ALLOWED_ORIGINS=[]
# Browser origins admitted above must also appear in GTEX_LINK_CORS_ORIGINS.
# GTEX_LINK_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# GTEX_LINK_CORS_ALLOW_CREDENTIALS=false

# API
# GTEX_LINK_API_RATE_LIMIT_PER_SECOND=5.0

# Cache
# GTEX_LINK_CACHE_SIZE=1000
# GTEX_LINK_CACHE_TTL=3600
